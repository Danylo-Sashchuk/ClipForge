# Copy this file to ".env" and adjust. All values have working defaults,
# so the only thing you usually need to set is the channel.

# ---- server ----
HOST=127.0.0.1
PORT=3001

# ---- which Kick channel to watch ----
KICK_CHANNEL_USERNAME=deenthegreat

# Kick's public Pusher app key (the website's). Only change if chat stops
# connecting: open kick.com -> F12 -> Network -> filter "pusher" -> copy the
# app id from the wss:// URL.
KICK_PUSHER_APP_KEY=32cbd69e4b950bf97679

STATUS_POLL_SECONDS=20

# ---- recorder ----
# streamlink (recommended) or ffmpeg
RECORDER_BACKEND=streamlink
STREAM_QUALITY=720p60,720p,best
SEGMENT_SECONDS=4
SEGMENT_RETENTION_SECONDS=600

# If ffmpeg / streamlink aren't on PATH, point to the full .exe path, e.g.
# FFMPEG_BIN=C:/ffmpeg/bin/ffmpeg.exe
# STREAMLINK_BIN=C:/Program Files/Streamlink/bin/streamlink.exe

# ---- clip timing (tune these against a real stream!) ----
# Chat reacts AFTER the moment. The real moment is ~LATENCY_OFFSET sec earlier.
LATENCY_OFFSET_SECONDS=10
PRE_PAD_SECONDS=22

# Dynamic end: clip stays open until chat calms down, then adds a small tail.
# Set DYNAMIC_END=false to go back to a fixed POST_PAD_SECONDS instead.
DYNAMIC_END=true
END_SCORE_THRESHOLD=35
END_HOLD_SECONDS=4
TAIL_OFFSET_SECONDS=3
MIN_CLIP_SECONDS=12
MAX_CLIP_SECONDS=90
POST_PAD_SECONDS=8

# ---- detection sensitivity ----
# Lower MIN_TRIGGER_SCORE = more clips (and more junk). Start ~75, tune.
MIN_TRIGGER_SCORE=75
TRIGGER_COOLDOWN_SECONDS=30
SHORT_WINDOW_SECONDS=5
LONG_WINDOW_SECONDS=60
MIN_MESSAGES_IN_WINDOW=8
SPIKE_RATIO_FOR_MAX=4
HOMOGENEITY_FOR_MAX=0.5
WEIGHT_SPIKE=0.5
WEIGHT_HOMOGENEITY=0.3
WEIGHT_KEYWORD=0.2

# ---- subtitles / captions (approved clips only) ----
# Model auto-downloads on first use. tiny=fastest/roughest, base=balanced,
# small/medium=better but slower on CPU.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
BURN_SUBTITLES=true
SUBTITLE_FONT_SIZE=18
